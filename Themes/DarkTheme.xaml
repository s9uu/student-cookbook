<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- BACKGROUND -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#4f5969"/>

    <!-- TEXT -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#dedede"/>

    <!-- BUTTONS -->
    <SolidColorBrush x:Key="GreenButtonBrush" Color="#21b858"/>
    <SolidColorBrush x:Key="YellowButtonBrush" Color="#e69408"/>
    <SolidColorBrush x:Key="RedButtonBrush" Color="#d63838"/>
    <SolidColorBrush x:Key="GrayButtonBrush" Color="#878f9c"/>
</ResourceDictionary>