<UserControl x:Class="StudentCookbook.Views.RecipeDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CardBackgroundBrush}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TYTUŁ -->
        <TextBlock Text="Spaghetti Carbonara"
               FontSize="28"
               FontWeight="Bold"
               Margin="0,0,0,20"
               Foreground="{DynamicResource PrimaryTextBrush}"/>

        <!-- GŁÓWNA SEKCJA -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ZDJĘCIE -->
            <Border Background="LightGray"
                CornerRadius="12"
                Width="350"
                Height="250">

                <Image Source="../Images/placeholder-food.png"
                   Stretch="Fill"/>
            </Border>

            <!-- SKŁADNIKI -->
            <StackPanel Grid.Column="2">

                <TextBlock Text="Składniki"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="• 200g makaronu spaghetti"
                       FontSize="14"
                       Margin="0,3"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="• 100g boczku"
                       FontSize="14"
                       Margin="0,3"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="• 2 jajka"
                       FontSize="14"
                       Margin="0,3"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="• 50g parmezanu"
                       FontSize="14"
                       Margin="0,3"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="• sól i pieprz"
                       FontSize="14"
                       Margin="0,3"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

            </StackPanel>

        </Grid>

        <!-- INSTRUKCJA -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">

            <TextBlock Text="Instrukcja wykonania"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>

            <Border Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="10"
                Padding="15">

                <TextBlock TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="Ugotuj makaron al dente. Podsmaż boczek na patelni. W misce wymieszaj jajka z parmezanem. Połącz makaron z boczkiem i zdejmij z ognia. Dodaj mieszankę jajek i szybko wymieszaj. Dopraw solą i pieprzem."/>
            </Border>

            <!-- POWRÓT -->
            <Button Content="⬅ Powrót"
                Width="120"
                Height="40"
                Margin="0,20,0,0"
                HorizontalAlignment="Left"
                Click="Back_Click"
                Background="{DynamicResource WindowBackgroundBrush}" 
                Foreground="{DynamicResource PrimaryTextBrush}"/>

        </StackPanel>

    </Grid>
</UserControl>