<Window x:Class="StudentCookbook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Studencka książka kucharska"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="*"/>
            <!-- Dynamic content -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom buttons -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Width="60"
                    Height="60"
                    Background="#D1D5DB"
                    CornerRadius="10"
                    VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold">
                    <Image Source=".\Images\book.png" Margin="5,5,5,5"/>
                </TextBlock>
            </Border>

            <TextBlock Grid.Column="1"
                       Text="STUDENCKA KSIĄŻKA KUCHARSKA"
                       FontFamily="Sharpie Variable"
                       FontSize="34"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="20,0,0,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>

            <Button Grid.Column="2"
                    Content="⚙"
                    Width="60"
                    Height="60"
                    FontSize="32"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    BorderBrush="#E5E7EB"
                    Cursor="Hand"
                    Click="Settings_Click"/>
        </Grid>

        <!-- SEARCH BAR -->
        <Grid Grid.Row="1">

            <Border HorizontalAlignment="Center"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,15">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Label Content="Wyszukaj po nazwie dania:"
                           FontSize="14" 
                           VerticalContentAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBox x:Name="SearchTextBox"
                         Height="35"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Margin="10,0,10,0"
                         Width="300"
                         Background="{DynamicResource CardBackgroundBrush}" 
                         Foreground="{DynamicResource PrimaryTextBrush}"    
                         />

                    <Button Content="🔎 Szukaj"
                        Width="120"
                        Height="35"
                        Background="{DynamicResource GreenButtonBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    </Button>

                </StackPanel>

            </Border>
        </Grid>

        <!-- DYNAMIC CONTENT -->
        <ContentControl x:Name="MainContentArea"
                        Grid.Row="2"/>

        <!-- BOTTOM BUTTONS -->
        <Grid Grid.Row="3" Margin="0,15,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        Grid.Column="1">

                <Button Content="➕ Dodaj"
                        Width="120"
                        Height="40"
                        Margin="5"
                        Background="{DynamicResource GreenButtonBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Add_Click"/>

                <Button Content="✏ Edytuj"
                        Width="120"
                        Height="40"
                        Margin="5"
                        Background="{DynamicResource YellowButtonBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Edit_Click"/>

                <Button Content="❌ Usuń"
                        Width="120"
                        Height="40"
                        Margin="5"
                        Background="{DynamicResource RedButtonBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Delete_Click"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>